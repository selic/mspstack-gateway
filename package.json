{
  "name": "mspstack-gateway-monorepo",
  "private": true,
  "version": "0.2.0",
  "description": "MSPStack Gateway — self-hosted MCP manager: one endpoint federating many MCP servers with OAuth, roles, secret storage, and tool toggles",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "dev": "npm run dev --workspace packages/gateway"
  },
  "engines": {
    "node": ">=24"
  },
