# MSPStack Gateway — environment knobs.
# Copy to docker/.env for compose, or export in your shell for `npm run dev`.
# At least ONE auth mechanism must be configured or the gateway refuses to start.

# ── Plumbing ─────────────────────────────────────────────────────────────────
PORT=3100
# Externally visible base URL (OAuth issuer/audience derive from it — must be
# the URL clients actually use):
PUBLIC_URL=http://localhost:3100
# SQLite path (":memory:" allowed; default data/gateway.db):
#DB_PATH=data/gateway.db
# Path to the declarative upstreams file (optional; default ./mspstack.config.json):
#MSPSTACK_CONFIG=mspstack.config.json
# Comma-separated browser origins allowed on /mcp (non-browser clients always pass):
#ALLOWED_ORIGINS=

# ── Auth: static bearer tokens ("label:token,…" per role) ───────────────────
MCP_TOKENS_ADMIN=me:change-me-openssl-rand-hex-24
#MCP_TOKENS_EDITOR=
#MCP_TOKENS_VIEWER=

# ── Auth: OAuth 2.1 resource server (Entra ID or any OIDC provider) ─────────
# ENTRA_TENANT_ID is shorthand for OIDC_ISSUER=https://login.microsoftonline.com/<tenant>/v2.0
#ENTRA_TENANT_ID=
#OIDC_ISSUER=
# Required with an issuer — tokens must be audience-bound to this gateway (RFC 8707):
#OIDC_AUDIENCE=api://<client-id>
# Claim holding group ids (default "groups"):
#OIDC_GROUPS_CLAIM=groups
# Comma list of emails/subs granted admin on first OIDC login:
#ADMIN_BOOTSTRAP_SUBJECTS=

# ── Interactive login (cookie + PKCE) + OAuth AS facade (DCR) ────────────────
# All-or-nothing; requires an OIDC issuer. Enables browser sign-in for /admin
# and /me AND the authorization-server facade that lets standard MCP clients
# connect with the URL alone (RFC 8414 metadata + RFC 7591 registration).
#AUTH_CLIENT_ID=
#AUTH_CLIENT_SECRET=
# Callback URL (default ${PUBLIC_URL}/auth/callback — must be registered on the IdP app):
#AUTH_REDIRECT_URI=
# HMAC key for session/transient cookies (≥16 chars):
#SESSION_SECRET=
# HS256 key for gateway-issued access tokens (optional; defaults to a key
# derived from SESSION_SECRET — set it to rotate independently):
#GATEWAY_JWT_SECRET=

# ── Mode ─────────────────────────────────────────────────────────────────────
# standalone (default) | integrated — integrated requires KEY_VAULT_URI + OIDC:
#GATEWAY_MODE=standalone

# ── Secrets store (one at a time) ────────────────────────────────────────────
# OpenBao / Vault KV v2 → enables "bao:path#field" refs:
#BAO_ADDR=http://openbao:8200
#BAO_MOUNT=mspstack
#BAO_TOKEN=
#BAO_ROLE_ID=
#BAO_SECRET_ID=
# Azure Key Vault via DefaultAzureCredential → enables "kv:secret-name" refs:
#KEY_VAULT_URI=

# ── Development only ─────────────────────────────────────────────────────────
# Anonymous requests get the admin role. Never expose beyond localhost:
#DEV_ALLOW_UNAUTHENTICATED=true
